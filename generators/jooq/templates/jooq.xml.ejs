<configuration xmlns="https://www.jooq.org/xsd/jooq-codegen-<%- jooqVersion %>.xsd">
  <generator>
    <target>
      <packageName><%= jooqTargetName %></packageName>
<%_ if (buildToolGradle) { _%>
      <directory>build/generated-src/jooq</directory>
<%_ } _%>
    </target>
    <database>
      <name>org.jooq.meta.extensions.liquibase.LiquibaseDatabase</name>
      <properties>
        <!-- Specify the location of your XML script. -->
        <property>
          <key>rootPath</key>
          <value>src/main/resources</value>
        </property>
        <property>
          <key>scripts</key>
          <value>config/liquibase/master.xml</value>
        </property>
        <!-- The property "changeLogParameters.contexts" will be passed on to the
             liquibase.database.Database.update() call (jOOQ 3.13.2+).
             See https://www.liquibase.org/documentation/contexts.html -->
        <property>
          <key>changeLogParameters.contexts</key>
          <value>prod</value>
        </property>
      </properties>
    </database>
  </generator>
</configuration>
