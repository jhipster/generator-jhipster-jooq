def jooqVersion = libs.versions.jooq.get().toString()

dependencies {
  implementation("org.springframework.boot:spring-boot-starter-jooq") {
    exclude group: "org.jooq", module: "*"
  }

  jooqCodegen "org.jooq:jooq-meta:${jooqVersion}"
  jooqCodegen files("src/main/resources")
}

jooq {
  configuration {
    generator {
      database {
        name = 'org.jooq.meta.extensions.liquibase.LiquibaseDatabase'
        properties {
          property {
            key = 'scripts'
            value = 'config/liquibase/master.xml'
          }
          property {
            key = 'changeLogParameters.contexts'
            value = 'prod'
          }
        }
      }
      target {
        packageName = '<%- jooqTargetName %>'
      }
    }
  }
}

compileJava.dependsOn jooqCodegen
